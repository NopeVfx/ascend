# ──────────────────────────────────────────────────────────────
# Ascend environment. Copy to `.env.local` and fill in what you have.
# Every integration is OPTIONAL — the app boots and degrades gracefully,
# showing a "connect this service" state where a key is missing.
# ──────────────────────────────────────────────────────────────

# Public site URL (used for OAuth + Stripe redirects)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Supabase (Auth, Profiles, Friends, Avatar storage) ──
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only. Used by the Stripe webhook to flip is_premium. NEVER expose client-side.
SUPABASE_SERVICE_ROLE_KEY=

# ── AI providers ──
# Standard (free) tier — Google Gemini. https://aistudio.google.com/app/apikey
GOOGLE_GENERATIVE_AI_API_KEY=
AI_STANDARD_MODEL=gemini-2.5-flash

# Premium tier. The premium analysis tries AI_PREMIUM_PROVIDER first, then the
# other configured providers, with OpenAI as the final fallback.
# Choose the primary premium provider: zai | anthropic | openai
AI_PREMIUM_PROVIDER=zai

# Z.ai (GLM) — OpenAI-compatible API. https://z.ai  (default primary; cheapest)
ZAI_API_KEY=
ZAI_BASE_URL=https://api.z.ai/api/paas/v4
AI_ZAI_MODEL=glm-4.6

# Anthropic (Claude). https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=
AI_ANTHROPIC_MODEL=claude-opus-4-1

# OpenAI (premium fallback). https://platform.openai.com/api-keys
OPENAI_API_KEY=
AI_OPENAI_MODEL=gpt-4o

# NOTE: Set the *_MODEL values to the exact model ids your providers accept
# (e.g. a GLM-5.x, Claude Opus 4.x, or GPT-5.x id once you have access).

# ── Stripe (Premium subscription) ──
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# A recurring Price created in the Stripe dashboard.
STRIPE_PRICE_ID=
# Display label only (the real charge is whatever STRIPE_PRICE_ID is set to).
NEXT_PUBLIC_PREMIUM_PRICE_LABEL=$19

# ── Meeting Room (PeerJS + matchmaking signaling server) ──
# Run `npm run server` (defaults to :3001). For local dev use the values below.
NEXT_PUBLIC_MATCHMAKING_URL=ws://localhost:3001/match
NEXT_PUBLIC_PEER_HOST=localhost
NEXT_PUBLIC_PEER_PORT=3001
NEXT_PUBLIC_PEER_PATH=/peerjs
NEXT_PUBLIC_PEER_SECURE=false
# Signaling server port (read by server/index.mjs)
PORT=3001
